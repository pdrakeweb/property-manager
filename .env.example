# Google OAuth Client ID (required for authentication)
# See docs/GOOGLE_OAUTH_SETUP.md for instructions
VITE_GOOGLE_CLIENT_ID=your-client-id-here
VITE_GOOGLE_CLIENT_SECRET=your-client-secret-here

# OpenRouter API key (optional — can also be set in Settings screen)
VITE_OPENROUTER_KEY=
# Home Assistant (optional — can also be set in Settings screen)
VITE_HA_URL=
VITE_HA_TOKEN=

# Dev model override — forces ALL AI tasks to use this model (ignores per-task settings)
# Remove or leave empty for normal per-task model selection
VITE_MODEL_OVERRIDE=

# Auth bypass for dev/CI — skips Google sign-in, uses mock auth state
# Set to "true" when running without Google credentials (e.g. automated testing)
VITE_AUTH_BYPASS=false
