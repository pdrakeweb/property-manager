{
  "name": "property-manager",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "docs:records": "node --import tsx scripts/generate-record-docs.mjs",
    "docs:records:check": "node --import tsx scripts/generate-record-docs.mjs --check",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:vault": "node --import tsx --test src/vault/__tests__/*.test.ts",
    "test:vault:live": "node --import tsx src/vault/__tests__/liveDrive.harness.ts"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "idb-keyval": "^6.2.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^6.28.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.59.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}
